includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 1
    paths:
        - app
        - database
        - routes
        - tests
    tmpDir: storage/framework/cache/phpstan
    excludePaths:
        analyse:
            - vendor
            - storage
            - bootstrap/cache
    ignoreErrors:
        -
            identifier: property.notFound
            path: app/Http/Resources/*
